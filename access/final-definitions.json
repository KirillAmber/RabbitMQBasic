      "name": "/"
    },
    {
      "name": "shop"
    },
    {
      "name": "analytics"
    }
  ],
  "permissions": [
    {
      "user": "guest",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "guest",
      "vhost": "shop",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "orders_service",
      "vhost": "shop",
      "configure": "^$",
      "write": "^x_orders$",
      "read": "^q_orders_processing$"
    },
    {
      "user": "analytics_service",
      "vhost": "shop",
      "configure": "^$",
      "write": "^$",
      "read": "^(q_orders_history|q_billing_events|q_payment_events)$"
    },
    {
      "user": "notification_service",
      "vhost": "shop",
      "configure": "^$",
      "write": "^$",
      "read": "^(q_email_notifications|q_sms_notifications)$"
    },
    {
      "user": "analytics_manager",
      "vhost": "analytics",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "topic_permissions": [
    {
      "user": "orders_service",
      "vhost": "shop",
      "exchange": "x_orders",
      "write": "^order\\..*$",
      "read": ".*"
    }
  ],
  "parameters": [],
  "global_parameters": [
    {
      "name": "cluster_name",
      "value": "rabbit@rabbitmq"
    }
  ],
  "policies": [],
  "exchanges": [
    {
      "name": "x_orders",
      "vhost": "shop",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "x_notifications",
      "vhost": "shop",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "x_events",
      "vhost": "analytics",
